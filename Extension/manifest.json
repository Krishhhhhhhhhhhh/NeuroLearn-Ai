{
  "manifest_version": 3,
  "name": "NeuroLearn AI Extractor",
  "version": "1.0",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "web_accessible_resources": [
    {
      "resources": [ "content.js" ],
      "matches": [ "<all_urls>" ]
    }
  ]
}